# Strata env template — copy to .env.local and fill in
# See plan/02-skeleton.md and plan/06-auth0.md

DATABASE_URL="file:./dev.db"

# Auth mode: stub (cookie-based dev) or auth0 (real Universal Login)
AUTH_MODE=stub

# Auth0 (only required when AUTH_MODE=auth0)
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://strata-api
AUTH0_SCOPE='openid profile email'

# Stub-mode session signing
NEXTAUTH_SECRET=

# DCP private compute group + worker callback shared secret
STRATA_GROUP_KEY=strata-2026
STRATA_GROUP_SECRET=
DCP_WORKER_SHARED_SECRET=
DCP_SUBMIT_WORKER_URL=http://localhost:3001

# Frontend (browser-exposed)
NEXT_PUBLIC_HF_TOKEN=
NEXT_PUBLIC_STRIPE_PK=
